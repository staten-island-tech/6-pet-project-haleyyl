
class Pet:
    def __init__(self,name, happiness, hunger, hygiene, living = True):
        self.name = name
        self.hunger = hunger
        self.happiness = happiness
        self.hygiene = hygiene
        self.living = living

    def statDec(self):
        self.happiness -= 5
        self.hunger -= 5
        self.hygiene -= 5

    def warnings(self):
        if self.happiness <= 20:
            print(f"{self.name} is not happy")
        elif self.happiness >= 75:
            print(f"{self.name} is very happy")
        if self.hunger <= 20:
            print(f"{self.name} is extremely hungry")
        elif self.hunger >= 80:
            print(f"{self.name} is full")
        if self.hygiene <= 35:
            print(f"{self.name} is stinky")
        elif self.hygiene >= 80:
            print(f"{self.name} is clean")
    
    def maxmin(self):
        if self.happiness > 100:
            self.happiness = 100
        elif self.happiness < 0:
            self.happiness = 0
        if self.hunger > 100:
            self.hunger = 100
        elif self.hunger < 0:
            self.hunger = 0
        if self.hygiene > 100:
            self.hygiene = 100
        elif self.hygiene < 0:
            self.hygiene = 0

    def clean(self):
        pet.hygiene += 35
        pet.happiness -= 5
    
    def play(self):
        pet.happiness += 20
        pet.hygiene -= 10
    
    def feed(self):
        pet.hunger += 40
        pet.happiness += 10
        pet.hygiene -= 5
    
    def rest(self):
        pet.happiness += 10
        pet.hygiene -= 5
    
    def ignore(self):
        pet.happiness -= 30
        pet.hygiene -= 10
        pet.hunger -= 15


    

print("welcome to Make a Pet.")
name = input("please enter a name for your pet")
pet = Pet(name,50,50,50)

while pet.living == True:
    Userinput = input("what do you want to do? Clean your pet, play with your pet, feed your pet, let your dog sleep, or ignore your pet")
    Userinput = Userinput.lower()
    if "clean" in Userinput:
        pet.clean()
        print(f"{name} is clean")
        pet.statDec()
        pet.warnings()
        pet.maxmin()
        print(f"{name} is {pet.happiness} percent happy")
        print(f"{name} is {pet.hunger} percent full ")
        print(f"{name} is {pet.hygiene} percent clean")
    elif "play" in Userinput:
        pet.play()
        print(f"{name} is having fun")
        pet.statDec
        pet.warnings()
        pet.maxmin()
        print(f"{name} is {pet.happiness} percent happy")
        print(f"{name} is {pet.hunger} percent full ")
        print(f"{name} is {pet.hygiene} percent clean")
    elif "feed" in Userinput:
        pet.feed()
        print(f"{name} is eating")
        pet.statDec
        pet.warnings()
        pet.maxmin()
        print(f"{name} is {pet.happiness} percent happy")
        print(f"{name} is {pet.hunger} percent full ")
        print(f"{name} is {pet.hygiene} percent clean")
    elif "sleep" in Userinput:
        pet.rest()
        print(f"{name} is sleeping")
        pet.statDec
        pet.warnings()
        pet.maxmin()
        print(f"{name} is {pet.happiness} percent happy")
        print(f"{name} is {pet.hunger} percent full ")
        print(f"{name} is {pet.hygiene} percent clean")
    elif "ignore" in Userinput:
        pet.ignore()
        print(f"{name} is feeling lonely")
        pet.statDec
        pet.warnings()
        pet.maxmin()
        print(f"{name} is {pet.happiness} percent happy")
        print(f"{name} is {pet.hunger} percent full ")
        print(f"{name} is {pet.hygiene} percent clean")
    elif "kill" in Userinput:
        print(f"{name} has died. Thank you for playing the game")
        break
    


    


