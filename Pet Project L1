class Dog:
    def __init__(self,name,happiness):
        self.name = name
        self.__happiness = happiness
    def play(self,play):
        self.__happiness += int(play)
    def show_status(self):
        print(f"{self.name} is now at {self.__happiness} % happiness")
Juno = Dog("Juno",5)
Juno.play(play=5)
Juno.show_status()
